{
  "version": "0.2.0",
  "configurations": [
      {
          "name": "Run Debug",
          "type": "cppdbg",
          "request": "launch",
          "program": "${workspaceFolder}/build/debug/bin/main.exe",
          "args": [],
          "stopAtEntry": false,
          "cwd": "${workspaceFolder}",
          "environment": [],
          "externalConsole": true,
          "MIMode": "gdb",
          "miDebuggerPath": "C:/msys64/usr/bin/gdb.exe",
          "setupCommands": [
              {
                  "description": "Enable pretty-printing for gdb",
                  "text": "-enable-pretty-printing",
                  "ignoreFailures": true
              }
          ],
          "preLaunchTask": "Build Debug",
          "internalConsoleOptions": "openOnSessionStart"
      }
  ]
}